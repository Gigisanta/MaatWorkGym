generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Plan {
  id          String   @id @default(cuid())
  nombre      String
  duracionDias Int
  precio      Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  socios      Socio[]
}

model Socio {
  id          String   @id @default(cuid())
  dni         String   @unique
  nombre      String
  apellido    String
  telefono    String?
  fechaNacimiento DateTime?
  fotoUrl     String?
  planId      String
  plan        Plan     @relation(fields: [planId], references: [id])
  fechaInicio DateTime
  horarioEntrenamiento String   @default("matutino")
  grupoMuscular       String?
  objetivoCliente     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  pagos       Pago[]
  fichajes    Fichaje[]
  rutinas     Rutina[]
  asignacionesRutina AsignacionRutina[]
  dietas      Dieta[]
  asignacionesDieta  AsignacionDieta[]
}

model Pago {
  id          String   @id @default(cuid())
  socioId     String
  socio       Socio    @relation(fields: [socioId], references: [id])
  monto       Float
  metodo      String
  fechaPago   DateTime @default(now())
  mes         Int
  anio        Int
  createdAt   DateTime @default(now())
}

model Fichaje {
  id           String    @id @default(cuid())
  socioId      String?
  socio        Socio?    @relation(fields: [socioId], references: [id])
  empleadoId   String?
  empleado     Empleado? @relation(fields: [empleadoId], references: [id])
  fechaHora    DateTime  @default(now())
  tipo         String    @default("entrada")
  notas        String?
  createdAt    DateTime  @default(now())
}

model Admin {
  id            String    @id @default(cuid())
  username      String    @unique
  passwordHash  String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?
  sessions      Session[]
}

model Session {
  id           String   @id @default(cuid())
  adminId      String
  admin        Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  ipAddress    String?
  userAgent    String?
}

model Empleado {
  id          String    @id @default(cuid())
  dni         String    @unique
  nombre      String
  apellido    String
  telefono    String?
  cargo       String?
  fechaInicio DateTime
  horarioEntrada String  @default("09:00")
  horarioSalida  String  @default("18:00")
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  fichajes    Fichaje[]
}

model Rutina {
  id          String    @id @default(cuid())
  nombre      String
  descripcion String?
  tipo        String    @default("generica")
  socioId     String?
  socio       Socio?    @relation(fields: [socioId], references: [id])
  token       String?   @unique
  dias        DiaRutina[]
  asignaciones AsignacionRutina[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model DiaRutina {
  id          String    @id @default(cuid())
  rutinaId    String
  rutina      Rutina    @relation(fields: [rutinaId], references: [id], onDelete: Cascade)
  diaSemana   Int
  nombre      String?
  ejercicios  EjercicioRutina[]
  orden       Int
}

model EjercicioRutina {
  id            String    @id @default(cuid())
  diaRutinaId   String
  diaRutina     DiaRutina @relation(fields: [diaRutinaId], references: [id], onDelete: Cascade)
  nombre        String
  series        Int
  repeticiones  String
  descanso      String
  grupoMuscular String?
  nota          String?
  orden         Int
}

model AsignacionRutina {
  id          String   @id @default(cuid())
  rutinaId    String
  rutina      Rutina   @relation(fields: [rutinaId], references: [id])
  socioId     String
  socio       Socio    @relation(fields: [socioId], references: [id])
  parametros  String?
  token       String   @unique
  createdAt   DateTime @default(now())

  @@unique([rutinaId, socioId])
}

model Dieta {
  id          String    @id @default(cuid())
  nombre      String
  descripcion String?
  tipo        String    @default("generica")
  socioId     String?
  socio       Socio?    @relation(fields: [socioId], references: [id])
  token       String?   @unique
  comidas     Comida[]
  asignaciones AsignacionDieta[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Comida {
  id        String      @id @default(cuid())
  dietaId   String
  dieta     Dieta       @relation(fields: [dietaId], references: [id], onDelete: Cascade)
  nombre    String
  hora      String
  orden     Int
  items     ItemComida[]
}

model ItemComida {
  id            String  @id @default(cuid())
  comidaId      String
  comida        Comida  @relation(fields: [comidaId], references: [id], onDelete: Cascade)
  alimento      String
  cantidad      String
  proteinas     Float?
  carbohidratos Float?
  grasas        Float?
  orden         Int
}

model AsignacionDieta {
  id          String   @id @default(cuid())
  dietaId     String
  dieta       Dieta    @relation(fields: [dietaId], references: [id])
  socioId     String
  socio       Socio    @relation(fields: [socioId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([dietaId, socioId])
}

// ============================================================
// E-COMMERCE MODELS
// ============================================================

model EcommerceCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  icon        String?
  description String?
  image       String?
  productCount Int      @default(0)
  sortOrder   Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  brand            String?
  categoryId       String
  category         EcommerceCategory @relation(fields: [categoryId], references: [id])
  subcategory      String?
  shortDescription String?
  description      String?
  image            String?
  gallery          String[]
  tags             String[]
  rating           Float     @default(0)
  reviewCount      Int       @default(0)
  featured         Boolean   @default(false)
  bestSeller      Boolean   @default(false)
  isNew            Boolean   @default(false)
  benefits         String[]
  ingredients      String?
  directions       String?
  warnings         String?
  servingsPerContainer Int?
  servingSize      String?
  nutritionFacts   Json?
  variants         ProductVariant[]
  orderItems       OrderItem[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model ProductVariant {
  id            String      @id @default(cuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  flavor        String
  size          String
  price         Float
  originalPrice Float?
  stock         Int         @default(0)
  sku           String      @unique
  orderItems    OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  status          String      @default("pending")
  // Customer info
  customerName    String
  customerEmail   String
  customerPhone   String?
  // Totals
  subtotal       Float
  shipping        Float       @default(0)
  discount        Float       @default(0)
  tax             Float       @default(0)
  total           Float
  // Shipping
  shippingAddress Json
  shippingMethod  String?
  paymentMethod  String?
  // Tracking
  trackingNumber String?
  carrier        String?
  estimatedDelivery String?
  // Coupon
  couponId       String?
  couponCode     String?
  // Notes
  notes          String?
  items          OrderItem[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model OrderItem {
  id         String          @id @default(cuid())
  orderId    String
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product         @relation(fields: [productId], references: [id])
  variantId  String
  variant    ProductVariant  @relation(fields: [variantId], references: [id])
  variantSku String
  name       String
  brand      String?
  flavor     String
  size       String
  price      Float
  quantity   Int
  image      String?
  createdAt  DateTime        @default(now())
}

model Coupon {
  id                  String    @id @default(cuid())
  code                String    @unique
  title               String
  description         String?
  discountType        String    @default("percentage")
  discountValue       Float
  minPurchase         Float     @default(0)
  maxDiscount         Float?
  usageLimit          Int?
  usedCount           Int       @default(0)
  validFrom           DateTime?
  validUntil          DateTime?
  applicableCategories String[]
  featured            Boolean   @default(false)
  active              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model EcommerceConfig {
  id                  String   @id @default(cuid())
  key                 String   @unique
  value               Json
  updatedAt           DateTime @updatedAt
}
