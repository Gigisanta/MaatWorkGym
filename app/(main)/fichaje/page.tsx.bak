"use client";
  const handleFichar = useCallback(async (socioId?: string) => {
    const id = socioId || socio?.id;
    if (!id) return;

    try {
      await createFichaje.mutateAsync(id);
      setJustFichado(true);

      setTimeout(() => {
        handleClear();
      }, 2500);
    } catch (err) {
      console.error("Error al fichar:", err);
    }
  }, [socio?.id, createFichaje, handleClear]);

  const handleSearch = useCallback(async () => {
    if (dni.length < 6) return;
    setShowCard(false);
    setNotFound(false);
    setJustFichado(false);
    setIsSearching(true);

    const result = await refetch();
    setIsSearching(false);
    if (result.data) {
      setShowCard(true);
      setNotFound(false);

      setTimeout(() => {
        handleFichar(result.data.id);
      }, 3000);
    } else if (result.isError) {
      setNotFound(true);
      setShowCard(false);
    }
  }, [dni, refetch, handleFichar]);

import { useState, useEffect, useCallback } from "react";
import { useSocioByDni, useCreateSocio } from "@/hooks/useSocios";
import { useCreateFichaje, useFichajes } from "@/hooks/useFichajes";
import { usePlanes } from "@/hooks/usePlanes";
import { User, Clock, AlertCircle, Check, X, ArrowRight, Calendar, ChevronLeft } from "lucide-react";

export default function FichajePage() {
  const [dni, setDni] = useState("");
  const [showCard, setShowCard] = useState(false);
  const [notFound, setNotFound] = useState(false);
  const [justFichado, setJustFichado] = useState(false);
  const [isSearching, setIsSearching] = useState(false);

  const { data: socio, refetch } = useSocioByDni(dni);
  const { data: fichajes } = useFichajes(true);
  const createFichaje = useCreateFichaje();
  const createSocio = useCreateSocio();
  const { data: planes } = usePlanes();

  const [showRegisterModal, setShowRegisterModal] = useState(false);
  const [newSocio, setNewSocio] = useState({
    nombre: "",
    apellido: "",
    dni: "",
    planId: "",
    fechaInicio: new Date().toISOString().split("T")[0],
  });

  const handleKeyPress = useCallback((num: string) => {
    if (dni.length < 12) {
      setDni((prev) => prev + num);

    const result = await refetch();
    setIsSearching(false);
    if (result.data) {
      setShowCard(true);
      setNotFound(false);

      setTimeout(() => {
        handleFichar(result.data.id);
      }, 3000);
    } else if (result.isError) {
      setNotFound(true);
      setShowCard(false);
    }
  }, [dni, refetch, handleFichar]);


  const handleRegister = async () => {
    if (!newSocio.nombre || !newSocio.apellido || !newSocio.dni || !newSocio.planId) {
      return;
    }

    try {
      await createSocio.mutateAsync(newSocio);
      setShowRegisterModal(false);
      const registeredDni = newSocio.dni;
      setNewSocio({
        nombre: "",
        apellido: "",
        dni: "",
        planId: "",
        fechaInicio: new Date().toISOString().split("T")[0],
      });
      setDni(registeredDni);
    } catch (err) {
      console.error("Error al registrar:", err);
    }
  };

  const getGreeting = () => {
    const hour = new Date().getHours();
    if (hour < 12) return "Buenos días";
    if (hour < 18) return "Buenas tardes";
    return "Buenas noches";
  };

  const formatTime = (date: Date) => {
    return new Date(date).toLocaleTimeString("es-AR", {
      hour: "2-digit",
      minute: "2-digit",
    });
  };

  const getTimeAgo = (date: Date) => {
    const now = new Date();
    const diff = Math.floor((now.getTime() - new Date(date).getTime()) / 1000 / 60);
    if (diff < 1) return "Ahora";
    if (diff < 60) return `Hace ${diff}m`;
    return formatTime(date);
  };

  const calculateAge = (fechaNacimiento: Date | string | null) => {
    if (!fechaNacimiento) return null;
    const today = new Date();
    const birth = new Date(fechaNacimiento);
    let age = today.getFullYear() - birth.getFullYear();
    const monthDiff = today.getMonth() - birth.getMonth();
    if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birth.getDate())) {
      age--;
    }
    return age;
  };

  return (
    <div className="min-h-screen p-6 lg:p-8" style={{ background: "var(--bg-primary)" }}>
      {/* Header */}
      <header className="mb-8">
        <p className="text-sm" style={{ color: "var(--text-muted)" }}>
          {getGreeting()}
        </p>
        <h1 className="text-2xl lg:text-3xl font-bold text-white mt-1">
          Panel de Fichaje
        </h1>
      </header>

      {/* Main Content - Two Column Layout */}
      <div className="flex flex-col lg:flex-row gap-6 lg:gap-8">
        {/* Left Column - 65% */}
        <div className="flex-1 lg:w-[65%]">
          {/* DNI Display */}
          <div
            className="card p-6 mb-6 animate-fade-in-up"
            style={{ background: "var(--bg-card)" }}
          >
            <div className="flex items-center justify-between mb-4">
              <div className="flex items-center gap-3">
                <div
                  className="w-12 h-12 rounded-2xl flex items-center justify-center"
                  style={{ background: "var(--violet-500)" }}
                >
                  <User className="w-6 h-6 text-white" />
                </div>
                <div>
                  <h2 className="text-lg font-bold text-white">Ingresá tu DNI</h2>
                  <p className="text-sm" style={{ color: "var(--text-muted)" }}>
                    Tocá los números para ingresar tu documento
                  </p>
                </div>
              </div>
              {dni && (
                <button
                  onClick={handleBackspace}
                  className="p-3 rounded-xl transition-colors"
                  style={{ background: "var(--bg-secondary)" }}
                >
                  <ChevronLeft className="w-5 h-5" style={{ color: "var(--text-secondary)" }} />
                </button>
              )}
            </div>

            {/* DNI Input Display */}
            <div
              className="p-4 rounded-2xl mb-6"
              style={{
                background: "var(--bg-secondary)",
                border: "1px solid var(--border)"
              }}
            >
              <div className="flex items-center justify-center min-h-[48px]">
                <span
                  className="text-3xl font-mono tracking-[0.3em] text-center"
                  style={{
                    color: dni ? "var(--text-primary)" : "var(--text-muted)"
                  }}
                >
                  {dni || "--------"}
                </span>
              </div>
            </div>

            {/* Keypad */}
            <div className="grid grid-cols-3 gap-3 mb-4">
              {["1", "2", "3", "4", "5", "6", "7", "8", "9"].map((num, i) => (
                <button
                  key={num}
                  onClick={() => handleKeyPress(num)}
                  className="keypad-btn aspect-square rounded-2xl font-semibold text-xl animate-fade-in-up"
                  style={{
                    background: "var(--bg-card)",
                    border: "1px solid var(--border)",
                    minHeight: "64px",
                    animationDelay: `${i * 30}ms`
                  }}
                >
                  <span className="text-white">{num}</span>
                </button>
              ))}
            </div>

            {/* Bottom Row */}
            <div className="grid grid-cols-3 gap-3">
              <button
                onClick={() => handleKeyPress("0")}
                className="keypad-btn aspect-square rounded-2xl font-semibold text-xl animate-fade-in-up"
                style={{
                  background: "var(--bg-card)",
                  border: "1px solid var(--border)",
                  minHeight: "64px",
                  animationDelay: "270ms"
                }}
              >
                <span className="text-white">0</span>
              </button>
              <button
                onClick={handleSearch}
                disabled={dni.length < 6}
                className="col-span-2 flex items-center justify-center gap-2 rounded-2xl font-semibold transition-all disabled:opacity-40 disabled:cursor-not-allowed animate-fade-in-up"
                style={{
                  background: dni.length >= 6 ? "var(--violet-500)" : "var(--bg-card)",
                  border: "1px solid var(--border)",
                  minHeight: "64px",
                  animationDelay: "300ms"
                }}
              >
                <span className="text-white">Buscar</span>
                <ArrowRight className="w-5 h-5 text-white" />
              </button>
            </div>

            {/* Clear Button */}
            <button
              onClick={handleClear}
              className="w-full mt-4 py-3 text-sm rounded-xl transition-colors animate-fade-in-up"
              style={{
                color: "var(--text-muted)",
                background: "transparent",
                animationDelay: "330ms"
              }}
            >
              Limpiar todo
            </button>
          </div>

          {/* Member Found Card */}
          {showCard && socio && !justFichado && (
            <div
              className="card p-6 animate-fade-in-up"
              style={{ background: "var(--bg-card)" }}
            >
              {isSearching ? (
                <div className="flex items-center justify-center py-8">
                  <div
                    className="w-8 h-8 rounded-full border-2 border-violet-500/30 border-t-violet-500 animate-spin"
                  />
                </div>
              ) : (
                <>
                  {/* Auto-fichando indicator */}
                  <div className="flex items-center gap-2 mb-4">
                    <div
                      className="w-2 h-2 rounded-full"
                      style={{ background: "var(--warning)", animation: "blink 1s ease-in-out infinite" }}
                    />
                    <span className="text-sm" style={{ color: "var(--warning)" }}>
                      Registrando entrada...
                    </span>
                  </div>

                  {/* Avatar & Name */}
                  <div className="flex items-center gap-4 mb-6">
                    <div
                      className="w-14 h-14 rounded-2xl flex items-center justify-center text-xl font-bold"
                      style={{ background: "var(--violet-500)" }}
                    >
                      {socio.nombre[0]}{socio.apellido[0]}
                    </div>
                    <div>
                      <h3 className="text-xl font-bold text-white">
                        {socio.nombre} {socio.apellido}
                      </h3>
                      <p className="text-sm" style={{ color: "var(--text-muted)" }}>
                        DNI: {socio.dni}
                      </p>
                    </div>
                    <div
                      className="ml-auto w-8 h-8 rounded-full flex items-center justify-center"
                      style={{
                        background: socio.tieneDeuda ? "var(--danger)" : "var(--success)"
                      }}
                    >
                      {socio.tieneDeuda ? (
                        <AlertCircle className="w-4 h-4 text-white" />
                      ) : (
                        <Check className="w-4 h-4 text-white" />
                      )}
                    </div>
                  </div>

                  {/* Info Grid */}
                  <div className="grid grid-cols-3 gap-3">
                    <div
                      className="p-4 rounded-xl"
                      style={{ background: "var(--bg-secondary)" }}
                    >
                      <p className="text-xs mb-1" style={{ color: "var(--text-muted)" }}>Plan</p>
                      <p className="font-semibold" style={{ color: "var(--violet-400)" }}>
                        {socio.plan.nombre}
                      </p>
                    </div>
                    <div
                      className="p-4 rounded-xl"
                      style={{ background: "var(--bg-secondary)" }}
                    >
                      <p className="text-xs mb-1" style={{ color: "var(--text-muted)" }}>Estado</p>
                      <p
                        className="font-semibold"
                        style={{ color: socio.tieneDeuda ? "var(--danger)" : "var(--success)" }}
                      >
                        {socio.tieneDeuda ? "DEBE" : "AL DÍA"}
                      </p>
                    </div>
                    <div
                      className="p-4 rounded-xl"
                      style={{ background: "var(--bg-secondary)" }}
                    >
                      <p className="text-xs mb-1" style={{ color: "var(--text-muted)" }}>Visitas mes</p>
                      <p className="font-bold text-xl text-white">{socio.visitasMesActual || 0}</p>
                    </div>
                  </div>
                </>
              )}
            </div>
          )}

          {/* Success State */}
          {justFichado && socio && (
            <div
              className="card p-8 text-center animate-fade-in-up"
              style={{ background: "var(--bg-card)" }}
            >
              <div
                className="w-20 h-20 mx-auto mb-4 rounded-full flex items-center justify-center"
                style={{ background: "rgba(16, 185, 129, 0.15)" }}
              >
                <Check className="w-10 h-10" style={{ color: "var(--success)" }} />
              </div>
              <h2 className="text-2xl font-bold text-white mb-2">Fichado</h2>
              <p className="text-lg mb-1" style={{ color: "var(--text-secondary)" }}>
                Bienvenido/a {socio.nombre}
              </p>
              <p className="text-sm" style={{ color: "var(--text-muted)" }}>
                {formatTime(new Date())}
              </p>
            </div>
          )}

          {/* Not Found State */}
          {notFound && (
            <div
              className="card p-8 text-center animate-fade-in-up"
              style={{ background: "var(--bg-card)" }}
            >
              <div
                className="w-20 h-20 mx-auto mb-4 rounded-full flex items-center justify-center"
                style={{ background: "rgba(239, 68, 68, 0.15)" }}
              >
                <AlertCircle className="w-10 h-10" style={{ color: "var(--danger)" }} />
              </div>
              <h2 className="text-xl font-bold text-white mb-2">Socio no encontrado</h2>
              <p className="text-sm mb-6" style={{ color: "var(--text-muted)" }}>
                No existe un socio registrado con este DNI
              </p>
              <button
                onClick={() => {
                  setShowRegisterModal(true);
                  setNewSocio((prev) => ({ ...prev, dni }));
                }}
                className="btn-primary w-full"
              >
                Registrar nuevo socio
              </button>
            </div>
          )}
        </div>

        {/* Right Column - 35% */}
        <div className="lg:w-[35%]">
          <div
            className="card p-6 animate-fade-in-up"
            style={{ background: "var(--bg-card)", animationDelay: "100ms" }}
          >
            {/* Greeting */}
            <div className="mb-6">
              <h3 className="text-xl font-bold text-white mb-1">{getGreeting()}</h3>
              <p className="text-sm" style={{ color: "var(--text-muted)" }}>
                {new Date().toLocaleDateString("es-AR", { weekday: "long", day: "numeric", month: "long" })}
              </p>
            </div>

            {/* Mini Client Info Card */}
            {showCard && socio && !justFichado && (
              <div
                className="mb-6 p-4 rounded-2xl animate-fade-in-up"
                style={{
                  background: "var(--bg-secondary)",
                  border: "1px solid var(--border)"
                }}
              >
                <div className="flex items-center gap-3 mb-4">
                  <div
                    className="w-10 h-10 rounded-xl flex items-center justify-center text-sm font-bold"
                    style={{ background: "var(--violet-500)" }}
                  >
                    {socio.nombre[0]}{socio.apellido[0]}
                  </div>
                  <div>
                    <p className="font-semibold text-white">{socio.nombre} {socio.apellido}</p>
                    <p className="text-xs" style={{ color: "var(--text-muted)" }}>DNI {socio.dni}</p>
                  </div>
                </div>
                <div className="space-y-2">
                  <div className="flex items-center justify-between text-sm">
                    <span style={{ color: "var(--text-muted)" }}>Plan</span>
                    <span className="font-medium" style={{ color: "var(--violet-400)" }}>{socio.plan.nombre}</span>
                  </div>
                  <div className="flex items-center justify-between text-sm">
                    <span style={{ color: "var(--text-muted)" }}>Edad</span>
                    <span className="font-medium text-white">
                      {calculateAge(socio.fechaNacimiento) !== null
                        ? `${calculateAge(socio.fechaNacimiento)} años`
                        : "No registrada"}
                    </span>
                  </div>
                  {socio.telefono && (
                    <div className="flex items-center justify-between text-sm">
                      <span style={{ color: "var(--text-muted)" }}>Teléfono</span>
                      <span className="font-medium text-white">{socio.telefono}</span>
                    </div>
                  )}
                </div>
              </div>
            )}

            {/* Today's Check-ins Header */}
            <div className="flex items-center justify-between mb-4">
              <div className="flex items-center gap-3">
                <div
                  className="w-10 h-10 rounded-xl flex items-center justify-center"
                  style={{ background: "var(--bg-secondary)" }}
                >
                  <Calendar className="w-5 h-5" style={{ color: "var(--violet-400)" }} />
                </div>
                <div>
                  <h4 className="font-semibold text-white">Fichajes de hoy</h4>
                  <p className="text-xs" style={{ color: "var(--text-muted)" }}>
                    {fichajes?.length || 0} registros
                  </p>
                </div>
              </div>
              <div
                className="px-3 py-1 rounded-full text-xs font-medium"
                style={{
                  background: "rgba(16, 185, 129, 0.15)",
                  color: "var(--success)"
                }}
              >
                {new Date().toLocaleDateString("es-AR", { day: "numeric", month: "short" })}
              </div>
            </div>

            {/* Check-ins List */}
            <div className="space-y-3 max-h-[400px] overflow-y-auto pr-1">
              {fichajes && fichajes.length > 0 ? (
                <>
                  {/* Live indicator */}
                  <div
                    className="flex items-center gap-2 px-3 py-2 rounded-xl mb-4"
                    style={{ background: "rgba(16, 185, 129, 0.05)", border: "1px solid var(--border)" }}
                  >
                    <div
                      className="w-2 h-2 rounded-full"
                      style={{ background: "var(--success)", animation: "blink 2s ease-in-out infinite" }}
                    />
                    <span className="text-xs" style={{ color: "var(--success)" }}>En vivo</span>
                  </div>

                  {fichajes.slice(0, 15).map((fichaje, index) => (
                    <div
                      key={fichaje.id}
                      className="p-4 rounded-2xl transition-all animate-fade-in-up"
                      style={{
                        background: "var(--bg-secondary)",
                        border: "1px solid var(--border)",
                        animationDelay: `${(index + 5) * 50}ms`
                      }}
                    >
                      <div className="flex items-center gap-3">
                        <div
                          className="w-10 h-10 rounded-xl flex items-center justify-center text-sm font-bold shrink-0"
                          style={{ background: "var(--violet-500)" }}
                        >
                          {fichaje.socio.nombre[0]}{fichaje.socio.apellido[0]}
                        </div>
                        <div className="flex-1 min-w-0">
                          <p className="font-medium text-white truncate">
                            {fichaje.socio.nombre} {fichaje.socio.apellido}
                          </p>
                          <p className="text-xs flex items-center gap-1" style={{ color: "var(--text-muted)" }}>
                            <Clock className="w-3 h-3" />
                            {getTimeAgo(fichaje.fechaHora)}
                            {index === 0 && (
                              <span className="ml-1" style={{ color: "var(--success)" }}>• Nuevo</span>
                            )}
                          </p>
                        </div>
                        <div
                          className="w-7 h-7 rounded-full flex items-center justify-center shrink-0"
                          style={{ background: index === 0 ? "rgba(16, 185, 129, 0.15)" : "var(--bg-card)" }}
                        >
                          <Check
                            className="w-4 h-4"
                            style={{ color: index === 0 ? "var(--success)" : "var(--violet-400)" }}
                          />
                        </div>
                      </div>
                    </div>
                  ))}
                </>
              ) : (
                <div className="text-center py-8">
                  <div
                    className="w-12 h-12 mx-auto mb-3 rounded-xl flex items-center justify-center"
                    style={{ background: "var(--bg-secondary)" }}
                  >
                    <Calendar className="w-6 h-6" style={{ color: "var(--text-muted)" }} />
                  </div>
                  <p className="text-sm" style={{ color: "var(--text-muted)" }}>Sin fichajes aún</p>
                </div>
              )}
            </div>
          </div>
        </div>
      </div>

      {/* Register Modal */}
      {showRegisterModal && (
        <div
          className="fixed inset-0 flex items-center justify-center p-4 z-50"
          style={{ background: "rgba(0, 0, 0, 0.7)", backdropFilter: "blur(8px)" }}
          onClick={(e) => {
            if (e.target === e.currentTarget) setShowRegisterModal(false);
          }}
        >
          <div
            className="card p-6 max-w-md w-full max-h-[90vh] overflow-y-auto animate-fade-in-up"
            style={{ background: "var(--bg-card)" }}
          >
            <div className="flex items-center justify-between mb-6">
              <div className="flex items-center gap-3">
                <div
                  className="w-10 h-10 rounded-xl flex items-center justify-center"
                  style={{ background: "var(--violet-500)" }}
                >
                  <User className="w-5 h-5 text-white" />
                </div>
                <h2 className="text-xl font-bold text-white">Registrar Nuevo Socio</h2>
              </div>
              <button
                onClick={() => setShowRegisterModal(false)}
                className="p-2 rounded-lg transition-colors"
                style={{ background: "var(--bg-secondary)" }}
              >
                <X className="w-5 h-5" style={{ color: "var(--text-secondary)" }} />
              </button>
            </div>

            <div className="space-y-4">
              <div>
                <label className="block text-sm mb-2" style={{ color: "var(--text-secondary)" }}>DNI</label>
                <input
                  type="text"
                  value={newSocio.dni}
                  onChange={(e) =>
                    setNewSocio((prev) => ({ ...prev, dni: e.target.value }))
                  }
                  className="input"
                  placeholder="Ej: 12345678"
                />
              </div>

              <div>
                <label className="block text-sm mb-2" style={{ color: "var(--text-secondary)" }}>Nombre</label>
                <input
                  type="text"
                  value={newSocio.nombre}
                  onChange={(e) =>
                    setNewSocio((prev) => ({ ...prev, nombre: e.target.value }))
                  }
                  className="input"
                  placeholder="Ej: Juan"
                />
              </div>

              <div>
                <label className="block text-sm mb-2" style={{ color: "var(--text-secondary)" }}>Apellido</label>
                <input
                  type="text"
                  value={newSocio.apellido}
                  onChange={(e) =>
                    setNewSocio((prev) => ({ ...prev, apellido: e.target.value }))
                  }
                  className="input"
                  placeholder="Ej: Pérez"
                />
              </div>

              <div>
                <label className="block text-sm mb-2" style={{ color: "var(--text-secondary)" }}>Plan</label>
                <select
                  value={newSocio.planId}
                  onChange={(e) =>
                    setNewSocio((prev) => ({ ...prev, planId: e.target.value }))
                  }
                  className="input"
                >
                  <option value="">Seleccionar plan...</option>
                  {planes?.map((plan) => (
                    <option key={plan.id} value={plan.id}>
                      {plan.nombre} - ${plan.precio}/mes
                    </option>
                  ))}
                </select>
              </div>

              <div>
                <label className="block text-sm mb-2" style={{ color: "var(--text-secondary)" }}>Fecha de inicio</label>
                <input
                  type="date"
                  value={newSocio.fechaInicio}
                  onChange={(e) =>
                    setNewSocio((prev) => ({ ...prev, fechaInicio: e.target.value }))
                  }
                  className="input"
                />
              </div>

              <div className="flex gap-3 pt-4">
                <button
                  onClick={() => setShowRegisterModal(false)}
                  className="btn-secondary flex-1"
                >
                  Cancelar
                </button>
                <button
                  onClick={handleRegister}
                  className="btn-primary flex-1"
                >
                  Registrar
                </button>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* Blink animation */}
      <style jsx global>{`
        @keyframes blink {
          0%, 100% { opacity: 1; }
          50% { opacity: 0.3; }
        }
      `}</style>
    </div>
  );
}
